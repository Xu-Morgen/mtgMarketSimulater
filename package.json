{
  "name": "mtg-market-simulator",
  "private": true,
  "packageManager": "pnpm@8.5.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @mtg-market/api --filter @mtg-market/web dev",
    "dev:web": "pnpm --filter @mtg-market/web dev",
    "dev:api": "pnpm --filter @mtg-market/api dev",
    "dev:ai": "pnpm --filter @mtg-market/ai dev",
    "build": "pnpm -r build",
    "check": "pnpm lint && pnpm -r check",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.9"
  }
}
