APP_ENV=development
PORT=3001
SQLITE_PATH=./data/market-simulator.db
WEB_ORIGIN=http://localhost:3000
# 多个浏览器来源以英文逗号分隔；未设置时仅允许 WEB_ORIGIN。
CORS_ORIGINS=http://localhost:3000
APP_TIMEZONE=Asia/Shanghai
# 至少 32 字符的随机服务端密钥；不可使用 NEXT_PUBLIC_ 前缀或提交到仓库。
AUTH_JWT_SECRET=R+t961CEZ9EC4HuS3hwF4KpSgbUlgCiy9D+ofYJQmf7oo1I+IRYku76w0vZUltc0
# 短期 access token 与可撤销 refresh Cookie 的生存时间（秒）。
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
# Scryfall 仅由 catalog.sync 后台任务访问；启用系列为空时任务会安全拒绝导入。
CATALOG_DATA_DIR=./data/catalog
SCRYFALL_BULK_ENDPOINT=https://api.scryfall.com/bulk-data/default-cards
# 标识服务端应用；请替换 contact 中的联系邮箱，Scryfall 会拒绝 Node 默认 User-Agent。
SCRYFALL_USER_AGENT=MTG-Market-Simulator/0.1 (contact: nemo5754@outlook.com)
CATALOG_ENABLED_SET_CODES=ONE,SOS
